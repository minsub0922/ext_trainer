# IE SFT PoC Environment Configuration
#
# Copy this file to .env and customize values for your local environment.
# DO NOT commit .env to version control (it's in .gitignore).
#
# For development:
#   cp .env.example .env
#   # Edit .env with your settings
#   python -m src.common.env load  # Validate and print config

# ============================================================================
# Project Configuration
# ============================================================================

# Project root directory (absolute or relative to where scripts run)
IESFT_PROJECT_ROOT=.

# Data directory containing raw and processed datasets
IESFT_DATA_DIR=./data

# Output directory for results, artifacts, checkpoints
IESFT_OUTPUT_DIR=./outputs

# Logs directory
IESFT_LOGS_DIR=./logs

# ============================================================================
# CUDA and GPU Configuration
# ============================================================================

# GPU device IDs to use (comma-separated, or empty for CPU)
# Examples:
#   CUDA_VISIBLE_DEVICES=0           # Use only GPU 0
#   CUDA_VISIBLE_DEVICES=0,1,2,3     # Use GPUs 0-3
#   CUDA_VISIBLE_DEVICES=             # Use all available GPUs
#   (empty)                           # Use CPU
CUDA_VISIBLE_DEVICES=0

# Enable cuBLAS for faster computation on NVIDIA GPUs
CUDA_USE_STATIC_CUDA_RUNTIME=1

# Optional: Limit GPU memory usage
# CUDA_DEVICE_ORDER=PCI_BUS_ID
# CUDA_LAUNCH_BLOCKING=1

# ============================================================================
# Weights & Biases (WandB) Configuration
# ============================================================================

# WandB project name for experiment tracking
WANDB_PROJECT=ie-sft-poc

# WandB entity (team or username)
WANDB_ENTITY=

# Disable WandB logging (set to true for offline work)
WANDB_DISABLED=true

# WandB API key (get from https://wandb.ai/settings/keys)
# Only needed if WANDB_DISABLED=false
# WANDB_API_KEY=

# WandB mode (online, offline, disabled)
WANDB_MODE=offline

# ============================================================================
# HuggingFace Configuration
# ============================================================================

# HuggingFace API token for downloading models and datasets
# Get token from https://huggingface.co/settings/tokens
HF_TOKEN=

# Disable HuggingFace telemetry
HF_HUB_DISABLE_TELEMETRY=1

# ============================================================================
# Model Configuration
# ============================================================================

# Default model family (qwen3 or olmo3)
DEFAULT_MODEL_FAMILY=qwen3

# Default model name from model registry
DEFAULT_MODEL_NAME=qwen3-0.6b

# Model cache directory (where downloaded models are stored)
HF_HOME=./models

# Use local model files instead of downloading from HuggingFace
# TRANSFORMERS_CACHE=./models

# ============================================================================
# Training Configuration
# ============================================================================

# Default learning rate for fine-tuning
TRAINING_LR=5e-5

# Default batch size
TRAINING_BATCH_SIZE=4

# Default number of epochs
TRAINING_EPOCHS=3

# Maximum sequence length for inputs
TRAINING_MAX_LENGTH=2048

# Enable mixed precision training (bf16 or fp16)
TRAINING_BF16=true

# Gradient accumulation steps
TRAINING_GRADIENT_ACCUMULATION=2

# ============================================================================
# Dataset Configuration
# ============================================================================

# Dataset registry file (relative to IESFT_PROJECT_ROOT)
DATASET_REGISTRY=data/metadata/dataset_registry.yaml

# Default dataset split to use (train, dev, test)
DEFAULT_DATASET_SPLIT=train

# ============================================================================
# Inference Configuration
# ============================================================================

# Default inference temperature (0.0-2.0)
INFERENCE_TEMPERATURE=0.7

# Default max generation length
INFERENCE_MAX_LENGTH=256

# Use quantized model for faster inference (GPTQ, AWQ)
INFERENCE_QUANTIZATION=false

# ============================================================================
# Logging and Debugging
# ============================================================================

# Logging level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Log to file in addition to console
LOG_TO_FILE=true

# Enable debug mode for verbose output
DEBUG=false

# Enable profiling (slows down execution)
ENABLE_PROFILING=false

# ============================================================================
# Validation and Testing
# ============================================================================

# Validate datasets on startup
VALIDATE_ON_STARTUP=true

# Validation mode (strict or lenient)
VALIDATION_MODE=strict

# ============================================================================
# OLMo3 PoC Configuration (experimental)
# ============================================================================

# Enable OLMo3 support (currently experimental)
OLMO3_ENABLED=false

# OLMo3 model path or HuggingFace ID (when available)
OLMO3_MODEL_PATH=allenai/OLMo3-base

# Use OLMo3 tokenizer (requires trust_remote_code=True)
OLMO3_TRUST_REMOTE_CODE=true

# ============================================================================
# Environment-Specific Overrides
# ============================================================================

# For production training (high-performance setup)
# CUDA_VISIBLE_DEVICES=0,1,2,3
# TRAINING_BATCH_SIZE=32
# TRAINING_GRADIENT_ACCUMULATION=1
# WANDB_DISABLED=false

# For quick development/testing (minimal resources)
# CUDA_VISIBLE_DEVICES=0
# TRAINING_BATCH_SIZE=2
# TRAINING_EPOCHS=1
# VALIDATE_ON_STARTUP=false
# LOG_LEVEL=WARNING

# For CPU-only (no GPU available)
# CUDA_VISIBLE_DEVICES=
# TRAINING_BATCH_SIZE=1
# TRAINING_BF16=false

# ============================================================================
# Example Usage
# ============================================================================

# 1. Basic setup:
#    - Copy this file to .env
#    - Edit CUDA_VISIBLE_DEVICES and HF_TOKEN
#    - Run training or inference
#
# 2. For multi-GPU training:
#    CUDA_VISIBLE_DEVICES=0,1,2,3
#    TRAINING_BATCH_SIZE=16
#    TRAINING_GRADIENT_ACCUMULATION=2
#
# 3. For remote/cloud setup:
#    HF_TOKEN=<your_token>
#    WANDB_API_KEY=<your_key>
#    IESFT_DATA_DIR=/mnt/data
#    IESFT_OUTPUT_DIR=/mnt/outputs
#
# 4. For OLMo3 experiments (when available):
#    DEFAULT_MODEL_FAMILY=olmo3
#    OLMO3_ENABLED=true
#    OLMO3_MODEL_PATH=<path_or_id>
